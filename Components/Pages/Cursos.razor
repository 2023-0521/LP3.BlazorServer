@page "/cursos"
@using LP3.BlazorServer.Application.Services
@using LP3.BlazorServer.Shared.DTOs

@inject ICursoService CursoService
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="container mt-4">
    <h1>📚 Gestión de Cursos</h1>
    <p class="text-muted">Aquí puedes Búsqueda, Creación, Listado, Edición y Eliminación de cursos</p>

    @*Búsqueda*@
    <div class="card-body"> 
        <div class="input-group"> 
            <InputText class="form-control" 
            @bind-Value="codigoBusqueda" placeholder="Ingrese el código del curso" />
            <button class="btn btn-primary" 
            @onclick="BuscarCurso"> 

            Buscar 

            </button> 

        </div> 
            @if (!string.IsNullOrEmpty(mensajeBusqueda))

            { <div class="alert alert-info mt-3"> 

                @mensajeBusqueda 

                </div> 
            } 
            @if (cursoEncontrado != null) 
            { 
                <table class="table table-striped mt-3">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Código</th>
                            <th>Créditos</th>

                        </tr>
                    </thead>

                    <tbody> 
                        <tr> 
                            <td>@cursoEncontrado.Nombre</td>
                            <td>@cursoEncontrado.Codigo</td> 
                            <td>@cursoEncontrado.Creditos</td> 
                        </tr> 
                    </tbody> 
                </table> 
            }
    </div>

    @* Registrar Curso *@

    <div class="card-body">
        <EditForm Model="nuevoCurso"
                OnValidSubmit="RegistrarCurso">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <InputText class="form-control"
                        @bind-Value="nuevoCurso.Nombre" />
                <ValidationMessage For="() => nuevoCurso.Nombre" />
            </div>

            <div class="mb-3">
                <label class="form-label">Código</label>
                <InputText class="form-control"
                        @bind-Value="nuevoCurso.Codigo" />
                <ValidationMessage For="() => nuevoCurso.Codigo" />
            </div>

            <div class="mb-3">
                <label class="form-label">Créditos</label>
                <InputNumber class="form-control"
                            @bind-Value="nuevoCurso.Creditos" />
                <ValidationMessage For="() => nuevoCurso.Creditos" />
            </div>

            <button type="submit"
                    class="btn btn-success">
                Guardar Curso
            </button>
        </EditForm>

        @if (!string.IsNullOrEmpty(mensajeRegistro))
        {
            <div class="alert mt-3 @(mensajeRegistro.StartsWith("✅") ? "alert-success" : "alert-danger")">
                @mensajeRegistro
            </div>
        }
    </div>

    @*Listado de cursos*@

  <div class="card mb-4">
    <div class="card-header">
        📋 Listado de Cursos
    </div>

    <div class="card-body">
        <button class="btn btn-primary mb-3"
                @onclick="CargarCursos">
            Cargar Cursos
        </button>

        @if (cursos.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Nombre</th>
                        <th>Código</th>
                        <th>Créditos</th>
                        <th>Activo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var curso in cursos)
                    {
                        <tr>
                            <td>@curso.Id</td>
                            <td>@curso.Nombre</td>
                            <td>@curso.Codigo</td>
                            <td>@curso.Creditos</td>
                            <td>@(curso.Activo ? "Sí" : "No")</td>
                            <td>
                                <button class="btn btn-warning btn-sm"
                                        @onclick="() => SeleccionarCurso(curso)">
                                    Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@*Edicion de Curso*@

@if (cursoEditar != null)
{
    <div class="card mb-4">
        <div class="card-header">
            ✏️ Editar Curso
        </div>

        <div class="card-body">
            <EditForm Model="cursoEditar"
                      OnValidSubmit="ActualizarCurso">

                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label>Nombre</label>
                    <InputText class="form-control"
                               @bind-Value="cursoEditar.Nombre" />
                </div>

                <div class="mb-3">
                    <label>Código</label>
                    <InputText class="form-control"
                               @bind-Value="cursoEditar.Codigo" />
                </div>

                <div class="mb-3">
                    <label>Créditos</label>
                    <InputNumber class="form-control"
                                 @bind-Value="cursoEditar.Creditos" />
                </div>

                <div class="form-check mb-3">
                    <InputCheckbox class="form-check-input"
                                   @bind-Value="cursoEditar.Activo" />
                    <label class="form-check-label">
                        Activo
                    </label>
                </div>

                <button type="submit"
                        class="btn btn-success">
                    Guardar Cambios
                </button>
            </EditForm>

            @if (!string.IsNullOrEmpty(mensajeEdicion))
            {
                <div class="alert mt-3 @(mensajeEdicion.StartsWith("✅") ? "alert-success" : "alert-danger")">
                    @mensajeEdicion
                </div>
            }
        </div>
    </div>
}


@*Eliminar Curso*@
@if (cursos.Any())
{
    <div class="card mb-4">
        <div class="card-header">
            🗑️ Eliminar Cursos
        </div>

        <div class="card-body">
            @foreach (var curso in cursos)
            {
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span>@curso.Nombre (@curso.Codigo)</span>
                    <button class="btn btn-danger btn-sm"
                            @onclick="() => ConfirmarEliminar(curso)">
                        Eliminar
                    </button>
                </div>
            }

            @if (!string.IsNullOrEmpty(mensajeEliminacion))
            {
                <div class="alert mt-3 @(mensajeEliminacion.StartsWith("✅") ? "alert-success" : "alert-danger")">
                    @mensajeEliminacion
                </div>
            }
        </div>
    </div>
}


@*finaliza el conteiner*@
</div>


@code {

    private string codigoBusqueda = string.Empty;
    private string mensajeBusqueda = string.Empty;

    private CursoDto? cursoEncontrado;

    private CursoDto nuevoCurso = new();

    private string mensajeRegistro = string.Empty;

    private async Task BuscarCurso()
    {
        cursoEncontrado = await CursoService.GetByCodigoAsync(codigoBusqueda);

        if (cursoEncontrado == null)
        {
            mensajeBusqueda = "❌ No se encontró ningún curso con ese código.";
        }
        else
        {
            mensajeBusqueda = "✅ Curso encontrado.";
        }
    }

    private async Task RegistrarCurso()
    {
        var resultado = await CursoService.CreateAsync(nuevoCurso);

        if (resultado)
        {
            mensajeRegistro = "✅ Curso registrado correctamente.";
            nuevoCurso = new CursoDto();
            await CargarCursos();
        }
        else
        {
            mensajeRegistro = "❌ Error al registrar el curso.";
        }
    }

    private List<CursoDto> cursos = new();

    private CursoDto? cursoEditar;

    private string mensajeEdicion = string.Empty;

    private async Task CargarCursos()
    {
        cursos = (await CursoService.GetAll()).ToList();
    }

    private void SeleccionarCurso(CursoDto curso)
    {
        cursoEditar = new CursoDto
        {
            Id = curso.Id,
            Nombre = curso.Nombre,
            Codigo = curso.Codigo,
            Creditos = curso.Creditos,
            Activo = curso.Activo
        };
    }

    private async Task ActualizarCurso()
    {
        if (cursoEditar == null)
            return;

        var resultado = await CursoService.UpdateAsync(
            cursoEditar.Id,
            cursoEditar);

        if (resultado)
        {
            mensajeEdicion = "✅ Curso actualizado correctamente.";
            await CargarCursos();
        }
        else
        {
            mensajeEdicion = "❌ Error al actualizar el curso.";
        }
    }


    private string mensajeEliminacion = string.Empty;
   private async Task ConfirmarEliminar(CursoDto curso)
{
    var confirmacion = await JSRuntime.InvokeAsync<bool>(
        "confirm",
        $"¿Estás seguro de eliminar el curso '{curso.Nombre}'?"
    );

    if (confirmacion)
    {
        var resultado = await CursoService.DeleteAsync(curso.Id);

        if (resultado)
        {
            mensajeEliminacion = "✅ Curso eliminado correctamente.";
            await CargarCursos();
        }
        else
        {
            mensajeEliminacion = "❌ Error al eliminar el curso.";
        }
    }
}

}